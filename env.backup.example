# Пример настроек для скриптов бэкапа PostgreSQL
# Скопируйте этот файл в .env и настройте под свои нужды

# === PostgreSQL настройки ===
POSTGRES_DB=cocktails_db
POSTGRES_USER=cocktails_user  
POSTGRES_PASSWORD=your_secure_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# === Другие настройки проекта (если нужны) ===
DEBUG=true
SECRET_KEY=your-secret-key-here

# === Настройки для тестирования ===
# Эти переменные используются скриптами бэкапа
# POSTGRES_DB - обязательно (имя базы данных)
# POSTGRES_USER - обязательно (пользователь для подключения)
# POSTGRES_PASSWORD - не используется в скриптах (доверие настроено в Docker)
# POSTGRES_HOST - не используется в скриптах (используется контейнер 'db')
# POSTGRES_PORT - не используется в скриптах (используется внутренний порт контейнера)
